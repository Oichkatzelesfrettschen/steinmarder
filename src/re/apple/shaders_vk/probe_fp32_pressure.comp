#version 450

layout(local_size_x = 64) in;

layout(set = 0, binding = 0) buffer OutBuffer {
    uint outData[];
};

void main() {
    uint gid = gl_GlobalInvocationID.x;
    float a = float((gid & 1023u) + 1u) * 0.25;
    float b = float(((gid * 9u) & 1023u) + 3u) * 0.125;
    float c = fma(a, 0.75, b);
    float d = sin(c) + cos(b);
    outData[gid] = floatBitsToUint(d);
}
