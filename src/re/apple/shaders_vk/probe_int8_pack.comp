#version 450

layout(local_size_x = 64) in;

layout(set = 0, binding = 0) buffer OutBuffer {
    uint outData[];
};

void main() {
    uint gid = gl_GlobalInvocationID.x;
    uint a = (gid & 0xffu);
    uint b = ((gid * 7u) & 0xffu);
    uint packed = (a & 0xffu) | ((b & 0xffu) << 8);
    packed |= ((a ^ b) & 0xffu) << 16;
    packed |= ((a + b) & 0xffu) << 24;
    outData[gid] = packed;
}
