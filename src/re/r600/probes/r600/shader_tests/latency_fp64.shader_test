[require]
GLSL >= 1.30
GL_ARB_gpu_shader_fp64

[vertex shader passthrough]

[fragment shader]
#version 130
#extension GL_ARB_gpu_shader_fp64 : enable
uniform float seed;
void main() {
    double v = double(seed + gl_FragCoord.x * 0.001);
    // 16-deep FP64 dependent chain
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    v = v * 1.0000001LF + 0.0000001LF;
    gl_FragColor = vec4(float(v), float(v), float(v), 1.0);
}

[test]
uniform float seed 0.5
draw rect -1 -1 2 2
