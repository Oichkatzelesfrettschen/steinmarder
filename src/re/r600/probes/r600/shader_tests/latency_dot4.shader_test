[require]
GLSL >= 1.30

[vertex shader passthrough]

[fragment shader]
#version 130
uniform float seed;
void main() {
    float px = gl_FragCoord.x * 0.001;
    float py = gl_FragCoord.y * 0.001;
    vec4 k = vec4(0.5 + px, 0.5 - px, 0.5 + py, 0.5 - py);
    vec4 v = vec4(seed + px, 0.5, 0.5, 0.5);
    float d;
    // 32-deep DOT4 chain
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    d = dot(v, k); v = vec4(d, d, d, d);
    gl_FragColor = vec4(d, d, d, 1.0);
}

[test]
uniform float seed 0.5
draw rect -1 -1 2 2
