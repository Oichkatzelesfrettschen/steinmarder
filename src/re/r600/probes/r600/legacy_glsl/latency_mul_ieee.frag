#version 130
// steinmarder latency probe: MUL_IEEE dependent chain
// Each multiply depends on the previous result → measures latency, not throughput
uniform float seed;
void main() {
    float v = seed + gl_FragCoord.x * 0.001;
    // 64-deep dependent chain of MUL_IEEE
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001; v = v * 1.0000001;
    gl_FragColor = vec4(v, v, v, 1.0);
}
