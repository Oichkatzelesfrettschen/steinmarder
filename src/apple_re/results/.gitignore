# xctrace bundles — each is 25-130 MB of binary CoreData/sqlite stores.
# Text exports (xctrace_*.xml, xctrace_*.csv) are committed; raw bundles are not.
*.trace/
*.trace

# Keepalive evidence tarballs — large bundle archives used for offline review.
# The individual text artifacts inside the blessed directories are committed instead.
*.tar.gz

# Compiled CPU probe binaries — regenerated by the build step in run_apple_tranche1.sh.
**/cpu_bins/

# Large OS-wide diagnostic dumps — spindump/sample capture every process on the
# system (10+ MB), not useful for reviewing shader probe behavior.
spindump_gpu_host.txt
sample_gpu_host.txt

# Compiled probe binaries and debug symbols — regenerated by build steps.
**/diagnostics/sm_apple_cpu_latency_asan
**/diagnostics/sm_apple_cpu_latency_asan.dSYM/

# Python cache
__pycache__/
*.pyc
